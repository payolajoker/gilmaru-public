{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://payolajoker.github.io/gilmaru-public/schemas/point-pack.schema.json",
  "title": "Gilmaru Point Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packId",
    "name",
    "language",
    "license",
    "maintainers",
    "points"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "packId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$"
    },
    "license": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "country",
        "city"
      ],
      "properties": {
        "country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 2
        },
        "province": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "city": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "district": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        }
      }
    },
    "maintainers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/maintainer"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/point"
      }
    }
  },
  "$defs": {
    "maintainer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "checkedAt": {
          "type": "string",
          "format": "date"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "coordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lat",
        "lng"
      ],
      "properties": {
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lng": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stepFree": {
          "type": "boolean"
        },
        "doorWidthCm": {
          "type": "number",
          "minimum": 0,
          "maximum": 1000
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        }
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "name",
        "coordinates",
        "status",
        "lastUpdated"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
        },
        "type": {
          "type": "string",
          "enum": [
            "entrance",
            "accessible_parking",
            "ramp",
            "elevator",
            "accessible_restroom",
            "rest_area",
            "meeting_point",
            "info_desk",
            "transit_stop",
            "quiet_room"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "gilmaruCode": {
          "type": "string",
          "pattern": "^A\\d{3}\\.B\\d{3}\\.C\\d{3}\\.D\\d{3}$"
        },
        "coordinates": {
          "$ref": "#/$defs/coordinates"
        },
        "status": {
          "type": "string",
          "enum": [
            "verified",
            "reported",
            "temporary",
            "inactive"
          ]
        },
        "verifiedAt": {
          "type": "string",
          "format": "date"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time"
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "accessibility": {
          "$ref": "#/$defs/accessibility"
        }
      }
    }
  }
}
