# Vite dev/build environments only
VITE_KAKAO_JS_KEY=your_kakao_javascript_key
VITE_MAP_PROVIDER=auto
VITE_OPEN_GEOCODER_MODE=auto
# Example: https://your-proxy.example.com/nominatim
VITE_OPEN_GEOCODER_BASE_URL=

# Optional local proxy process
# OPEN_GEOCODER_HOST=127.0.0.1
# OPEN_GEOCODER_PORT=8787
# OPEN_GEOCODER_CONTACT_EMAIL=you@example.com
